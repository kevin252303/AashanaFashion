<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Aashana Fashion</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    var role     = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity.Name ?? "";
    var initials = string.Concat(fullName.Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString() : "")).ToUpper();
    var ctrl     = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action   = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    bool isSuperAdmin = role == "SuperAdmin";
    bool isAdmin      = role == "Admin" || isSuperAdmin;

    // Permission helpers — check claims for custom roles
    bool canViewDesign      = isAdmin || User.HasClaim("Permission.DesignMaster.CanView",    "true");
    bool canViewVendor      = isAdmin || User.HasClaim("Permission.VendorMaster.CanView",    "true");
    bool canCreateOrder     = isAdmin || User.HasClaim("Permission.ProductionOrder.CanCreate", "true");
    bool canViewUserMgmt    = isAdmin || User.HasClaim("Permission.UserManagement.CanView",  "true");

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">AF</div>
            <div>
                <div class="brand-name">Aashana Fashion</div>
                <div class="brand-sub">Production System</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-label">Main</div>
            <a class="s-link @(ctrl == "Production" && action == "Index" ? "active" : "")"
               asp-controller="Production" asp-action="Index">
                <span class="ico">📦</span> Production Orders
            </a>

            @if (canViewDesign)
            {
                <a class="s-link @(ctrl == "Design" ? "active" : "")"
                   asp-controller="Design" asp-action="Index">
                    <span class="ico">🎨</span> Design Master
                </a>
            }
            @if (canViewVendor)
            {
                <a class="s-link @(ctrl == "Vendor" ? "active" : "")"
                   asp-controller="Vendor" asp-action="Index">
                    <span class="ico">🏢</span> Vendor Master
                </a>
            }

            @if (canCreateOrder)
            {
                <a class="s-link @(ctrl == "Production" && action == "Create" ? "active" : "")"
                   asp-controller="Production" asp-action="Create">
                    <span class="ico">➕</span> New Order
                </a>
            }

            @if (canViewUserMgmt)
            {
                <div class="nav-label">Users</div>
                <a class="s-link s-link-toggle @(ctrl == "UserManagement" || ctrl == "Role" ? "open" : "")" onclick="toggleNav(this)">
                    <span class="ico">👥</span> User Management
                    <span class="nav-arrow">▾</span>
                </a>
                <div class="s-submenu @(ctrl == "UserManagement" || ctrl == "Role" ? "" : "d-none")">
                    <a class="s-link s-sublink @(ctrl == "UserManagement" && action == "Index" ? "active" : "")"
                       asp-controller="UserManagement" asp-action="Index">
                        <span class="ico">📋</span> User List
                    </a>
                    @if (isAdmin)
                    {
                        <a class="s-link s-sublink @(ctrl == "Role" ? "active" : "")"
                           asp-controller="Role" asp-action="Index">
                            <span class="ico">🔐</span> Role List
                        </a>
                    }
                </div>
            }
        </nav>

        <div class="role-pill rp-@role">@role</div>
    </aside>

    <div class="topbar">
        <div class="topbar-left">
            <span class="page-title">@(ViewData["Title"] ?? "Dashboard")</span>
        </div>
        <div class="user-chip">
            <div class="u-avatar">@initials</div>
            <div>
                <div class="u-name">@fullName</div>
                <div class="u-role">@role</div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0 ms-2">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-af btn-af-ghost btn-af-sm">Logout</button>
            </form>
        </div>
    </div>

    <div class="main-wrap">
        <div class="page-body">
            @RenderBody()
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function toggleNav(el) {
        el.classList.toggle('open');
        var sub = el.nextElementSibling;
        sub.classList.toggle('d-none');
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
