@model AashanaFashion.Models.Design
@{
    ViewData["Title"] = "Edit Design";
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-xl-5">
        <div class="data-card">
            <div class="data-card-header">
                <div>
                    <div class="data-card-title">Edit Design — @Model.DesignNumber</div>
                    <div style="font-size:.75rem;color:#94a3b8;margin-top:.2rem;">ID #@Model.Id</div>
                </div>
                <a asp-action="Index" class="btn-af btn-af-ghost btn-af-sm">← Back</a>
            </div>
            <div style="padding:1.5rem;">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" name="CreatedDate" value="@Model.CreatedDate.ToString("yyyy-MM-ddTHH:mm:ss")" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="af-alert af-alert-danger mb-3">
                            @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            { <div>@e.ErrorMessage</div> }
                        </div>
                    }

                    <div class="af-form-group">
                        <label asp-for="DesignNumber" class="af-label">Design Number</label>
                        <input asp-for="DesignNumber" class="af-input" />
                        <span asp-validation-for="DesignNumber" class="af-error"></span>
                    </div>

                    <div class="af-form-group">
                        <label asp-for="Colours" class="af-label">Colours</label>
                        <input asp-for="Colours" class="af-input" />
                        <span style="font-size:.75rem;color:#94a3b8;">Comma-separated list</span>
                    </div>

                    <div class="af-form-group">
                        <label asp-for="Sizes" class="af-label">Sizes</label>
                        <input asp-for="Sizes" class="af-input" />
                        <span style="font-size:.75rem;color:#94a3b8;">Comma-separated list</span>
                    </div>

                    <div class="af-form-group">
                        <label asp-for="Price" class="af-label">Price (₹)</label>
                        <input asp-for="Price" class="af-input" type="number" step="0.01" min="0" />
                    </div>

                    <div class="af-form-group">
                        <label asp-for="CreationFlow" class="af-label">Creation Flow</label>
                        <input asp-for="CreationFlow" class="af-input" />
                    </div>

                    <div style="display:flex;gap:.75rem;margin-top:1.5rem;">
                        <button type="submit" class="btn-af btn-af-primary">Save Changes</button>
                        <a asp-action="Index" class="btn-af btn-af-ghost">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
