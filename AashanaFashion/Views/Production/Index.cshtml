@model IEnumerable<AashanaFashion.Models.BatchDashboardViewModel>
@{
    ViewData["Title"] = "Production Orders";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
}

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon si-blue">📦</div>
            <div><div class="stat-val">@ViewBag.Total</div><div class="stat-lbl">Total Orders</div></div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon si-yellow">⚙️</div>
            <div><div class="stat-val">@ViewBag.InProgress</div><div class="stat-lbl">In Progress</div></div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon si-green">✅</div>
            <div><div class="stat-val">@ViewBag.ReadyToDispatch</div><div class="stat-lbl">Ready to Dispatch</div></div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon si-gray">🚚</div>
            <div><div class="stat-val">@ViewBag.Dispatched</div><div class="stat-lbl">Dispatched</div></div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="data-card">
    <div class="data-card-header">
        <span class="data-card-title">All Production Orders</span>
        @if (role == "Admin")
        {
            <a asp-action="Create" class="btn-af btn-af-primary btn-af-sm">+ New Order</a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="es-icon">📦</div>
            <p>No production orders found.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="af-table">
                <thead>
                    <tr>
                        <th class="ps-4">#</th>
                        <th>Design No.</th>
                        <th>Qty</th>
                        @* <th>Pieces</th> *@
                        <th>Stage</th>
                        @* <th>Progress</th> *@
                        <th>Status</th>
                        @if (role == "Admin" || role == "Manager")
                        {
                            <th>Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">@item.Id</td>
                            <td>
                                <span style="font-weight:600;color:#0f172a;">@item.DesignNumber</span>
                                <br><span style="font-size:.75rem;color:#94a3b8;">@item.LotNo</span>
                            </td>
                            <td>@item.TotalQuantity <span style="color:#94a3b8;font-size:.75rem;">pcs</span></td>
                            @* <td>
                                @foreach (var step in item.CreationSteps)
                                {
                                    var stepKey = step.Trim();
                                    var isDone = item.VerificationStatus.ContainsKey(stepKey) && item.VerificationStatus[stepKey];
                                    <span class="af-badge @(isDone ? "b-green" : "b-gray")" style="margin-right:3px;" title="@step">@step.Substring(0, Math.Min(3, step.Length)).ToUpper()</span>
                                }
                            </td> *@
                            <td><span class="af-badge @GetStageBadge(item.Status)">@item.CurrentStage</span></td>
                            @* <td style="min-width:120px;">
                                <div class="af-progress mb-1">
                                    <div class="af-progress-bar"
                                         style="width:@item.ProgressPercentage%; background:@(item.ProgressPercentage==100?"#22c55e":"#6366f1");"></div>
                                </div>
                                <span style="font-size:.72rem;color:#94a3b8;">@item.ProgressPercentage%</span>
                            </td> *@
                            <td>
                                @if (item.Status == AashanaFashion.Models.OrderStatus.Dispatched)
                                { <span class="af-badge b-gray">Dispatched</span> }
                                else if (item.Status == AashanaFashion.Models.OrderStatus.ReadyToDispatch)
                                { <span class="af-badge b-green">Ready</span> }
                                else
                                { <span class="af-badge b-yellow">In Progress</span> }
                            </td>
                            @if (role == "Admin" || role == "Manager")
                            {
                                <td>
                                    <div style="display:flex;gap:.4rem;">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-af btn-af-ghost btn-af-sm">Edit</a>
                                        @if (role == "Admin")
                                        {
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Delete this order?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-af btn-af-sm" style="background:#fef2f2;color:#dc2626;border:1px solid #fecaca;">Delete</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@functions {
    string GetStageBadge(AashanaFashion.Models.OrderStatus s) => s switch {
        AashanaFashion.Models.OrderStatus.RawMaterialArrived => "b-gray",
        AashanaFashion.Models.OrderStatus.AtDying            => "b-cyan",
        AashanaFashion.Models.OrderStatus.AtHandwork         => "b-yellow",
        AashanaFashion.Models.OrderStatus.AtStitching        => "b-purple",
        AashanaFashion.Models.OrderStatus.ReadyToDispatch    => "b-green",
        AashanaFashion.Models.OrderStatus.Dispatched         => "b-gray",
        _                                                    => "b-gray"
    };
}
