<table class="table table-hover">
    <thead>
        <tr>
            <th>Design #</th>
            <th>Batch Size</th>
            <th>Set Composition (G-C-D)</th>
            <th>Current Stage</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.DesignNumber</strong></td>
                <td>@item.TotalQuantity Pcs</td>
                <td>
                    <span class="badge @(item.IsGhagraDone ? "bg-success" : "bg-light text-dark border")">G</span>
                    <span class="badge @(item.IsCholiDone ? "bg-success" : "bg-light text-dark border")">C</span>
                    <span class="badge @(item.IsDupattaDone ? "bg-success" : "bg-light text-dark border")">D</span>
                </td>
                <td><span class="badge bg-info">@item.CurrentStage</span></td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Update Status</a>
                </td>
            </tr>
        }
    </tbody>
</table>