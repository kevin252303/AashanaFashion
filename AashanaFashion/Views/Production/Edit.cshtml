@model AashanaFashion.Models.ProductionOrder
@{
    ViewData["Title"] = "Edit Order";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var designs = ViewBag.Designs as List<AashanaFashion.Models.Design> ?? new List<AashanaFashion.Models.Design>();
    var statusOptions = string.Join("", Enum.GetValues<AashanaFashion.Models.OrderStatus>()
        .Select(s => $"<option value=\"{s}\" {(s == Model.Status ? "selected" : "")}>{s}</option>"));
}

<div class="page-header">
    <div>
        <h1 class="page-title">Edit Order — @Model.LotNo</h1>
        <p class="page-sub">Design: @Model.Design?.DesignNumber</p>
    </div>
    <a asp-action="Index" class="btn-af btn-af-ghost btn-af-sm">← Back</a>
</div>

<div class="row">
    <div class="col-lg-5">
        <div class="data-card mb-3">
            <div class="data-card-header">
                <div class="data-card-title">Order Details</div>
            </div>
            <div style="padding:1.5rem;">
                <form asp-action="Edit" method="post" id="orderForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" asp-for="CreatedDate" />

                    @if (role == "Admin")
                    {
                        <div class="af-form-group">
                            <label class="af-label">Design</label>
                            <select name="DesignId" class="af-input af-select" id="designSelect">
                                @Html.Raw(string.Join("", designs.Select(d => 
                                    $"<option value=\"{d.Id}\" data-colours=\"{d.Colours}\" data-sizes=\"{d.Sizes}\" {(d.Id == Model.DesignId ? "selected" : "")}>{d.DesignNumber}</option>")))
                            </select>
                        </div>
                        <div class="af-form-group">
                            <label class="af-label">Lot No</label>
                            <input type="text" name="LotNo" class="af-input" value="@Model.LotNo" />
                        </div>
                        <div class="af-form-group">
                            <label class="af-label">Fabric Type</label>
                            <input type="text" name="FabricType" class="af-input" value="@Model.FabricType" />
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="DesignId" value="@Model.DesignId" />
                        <div class="af-form-group">
                            <label class="af-label">Design</label>
                            <input type="text" class="af-input" value="@Model.Design?.DesignNumber" disabled style="background:#f8fafc;" />
                        </div>
                        <div class="af-form-group">
                            <label class="af-label">Lot No</label>
                            <input type="text" class="af-input" value="@Model.LotNo" disabled style="background:#f8fafc;" />
                        </div>
                    }

                    <div class="af-form-group">
                        <label class="af-label">Status</label>
                        <select name="Status" class="af-input af-select">
                            @Html.Raw(statusOptions)
                        </select>
                    </div>

                    <div class="af-form-group">
                        <label class="af-label">Verification Checklist</label>
                        <div style="background:#f8fafc;border-radius:10px;padding:1rem;display:flex;flex-direction:column;gap:.75rem;">
                            <label style="display:flex;align-items:center;gap:.6rem;cursor:pointer;">
                                <input type="checkbox" name="IsRawMaterialVerified" @(Model.IsRawMaterialVerified ? "checked" : "") style="accent-color:#6366f1;width:16px;height:16px;" />
                                Raw Material Verified
                            </label>
                            <label style="display:flex;align-items:center;gap:.6rem;cursor:pointer;">
                                <input type="checkbox" name="IsDyingVerified" @(Model.IsDyingVerified ? "checked" : "") style="accent-color:#6366f1;width:16px;height:16px;" />
                                Dying Verified
                            </label>
                            <label style="display:flex;align-items:center;gap:.6rem;cursor:pointer;">
                                <input type="checkbox" name="IsHandworkVerified" @(Model.IsHandworkVerified ? "checked" : "") style="accent-color:#6366f1;width:16px;height:16px;" />
                                Handwork Verified
                            </label>
                            <label style="display:flex;align-items:center;gap:.6rem;cursor:pointer;">
                                <input type="checkbox" name="IsStitchingVerified" @(Model.IsStitchingVerified ? "checked" : "") style="accent-color:#6366f1;width:16px;height:16px;" />
                                Stitching Verified
                            </label>
                        </div>
                    </div>

                    <input type="hidden" id="totalQuantity" name="TotalQuantity" value="@Model.TotalQuantity" />
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="data-card">
            <div class="data-card-header">
                <div class="data-card-title">Colour & Size Matrix</div>
                <span class="af-badge b-blue" id="totalPieces">Total: @Model.TotalQuantity pcs</span>
            </div>
            <div style="padding:1.5rem;">
                <div id="matrixContainer">
                    <div class="text-center p-4 text-muted" id="matrixPlaceholder" style="display:none;">
                        Select a design to see colour/size matrix
                    </div>
                    <div id="matrixGrid">
                        <table class="af-table" id="matrixTable">
                            <thead>
                                <tr>
                                    <th>Colour</th>
                                </tr>
                            </thead>
                            <tbody id="matrixBody"></tbody>
                        </table>
                    </div>
                </div>

                <div style="display:flex;gap:.75rem;margin-top:1.5rem;">
                    <button type="submit" form="orderForm" class="btn-af btn-af-primary">Save Changes</button>
                    <a asp-action="Index" class="btn-af btn-af-ghost">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        var existingDetails = @Html.Raw(Json.Serialize(Model.Details.Select(d => new { colour = d.Colour, size = d.Size, quantity = d.Quantity })));
    </script>
    <script src="~/js/production-edit.js"></script>
}
