@model AashanaFashion.Models.ProductionOrder
@{
    ViewData["Title"] = "Edit Order";
    var role       = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    bool isAdmin   = role == "Admin" || role == "SuperAdmin";
    var designs    = ViewBag.Designs as List<AashanaFashion.Models.Design> ?? new List<AashanaFashion.Models.Design>();
    var currentDesign  = designs.FirstOrDefault(d => d.Id == Model.DesignId);
    var creationSteps  = currentDesign?.GetCreationSteps() ?? new List<string>();
    var statusOptions  = string.Join("", Enum.GetValues<AashanaFashion.Models.OrderStatus>()
        .Select(s => $"<option value=\"{s}\" {(s == Model.Status ? "selected" : "")}>{s}</option>"));
}

<div class="page-header">
    <div>
        <h1 class="page-title">Edit Order — @Model.LotNo</h1>
        <p class="page-sub">Design: @Model.Design?.DesignNumber</p>
    </div>
    <a asp-action="Index" class="btn-af btn-af-ghost btn-af-sm">← Back</a>
</div>

<form asp-action="Edit" method="post" id="orderForm">
@Html.AntiForgeryToken()
<input type="hidden" name="id" value="@Model.Id" />
<input type="hidden" name="CreatedDate" value="@Model.CreatedDate.ToString("yyyy-MM-ddTHH:mm:ss")" />

<div class="row">
    <div class="col-lg-4">
        <div class="data-card mb-3">
            <div class="data-card-header">
                <div class="data-card-title">Order Details</div>
            </div>
            <div style="padding:1.5rem;">

                    @if (isAdmin)
                    {
                        <div class="af-form-group">
                            <label class="af-label">Design</label>
                            <select name="DesignId" class="af-input af-select" id="designSelect">
                                @Html.Raw(string.Join("", designs.Select(d => 
                                    $"<option value=\"{d.Id}\" data-colours=\"{d.Colours}\" data-sizes=\"{d.Sizes}\" data-steps=\"{d.CreationFlow}\" {(d.Id == Model.DesignId ? "selected" : "")}>{d.DesignNumber}</option>")))
                            </select>
                        </div>
                        <div class="af-form-group">
                            <label class="af-label">Lot No</label>
                            <input type="text" name="LotNo" class="af-input" value="@Model.LotNo" />
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="DesignId" value="@Model.DesignId" />
                        <div class="af-form-group">
                            <label class="af-label">Design</label>
                            <input type="text" class="af-input" value="@Model.Design?.DesignNumber" disabled style="background:#f8fafc;" />
                        </div>
                        <div class="af-form-group">
                            <label class="af-label">Lot No</label>
                            <input type="text" class="af-input" value="@Model.LotNo" disabled style="background:#f8fafc;" />
                        </div>
                    }

                    <div class="af-form-group">
                        <label class="af-label">Status</label>
                        <select name="Status" class="af-input af-select">
                            @Html.Raw(statusOptions)
                        </select>
                    </div>

                    <div class="af-form-group" id="verificationSection" style="display:none;">
                        <label class="af-label">Verification Checklist <span class="text-muted" style="font-weight:normal;">(based on: @currentDesign?.CreationFlow)</span></label>
                        <div style="background:#f8fafc;border-radius:10px;padding:1rem;display:flex;flex-direction:column;gap:.75rem;" id="verificationContainer">
                        </div>
                    </div>

                    <input type="hidden" id="totalQuantity" name="TotalQuantity" value="@Model.TotalQuantity" />

                    <div style="display:flex;gap:.75rem;margin-top:1rem;">
                        <button type="submit" class="btn-af btn-af-primary">Save Changes</button>
                        <a asp-action="Index" class="btn-af btn-af-ghost">Cancel</a>
                    </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="data-card">
            <div class="data-card-header">
                <div class="data-card-title">Colour & Size Matrix</div>
                <span class="af-badge b-blue" id="totalPieces">Total: @Model.TotalQuantity pcs</span>
            </div>
            <div style="padding:1rem;">
                <div id="matrixContainer">
                    <div class="text-center p-4 text-muted" id="matrixPlaceholder" style="display:none;">
                        Select a design to see colour/size matrix
                    </div>
                    <div id="matrixGrid" style="overflow-x:auto;">
                        <table class="af-table" id="matrixTable" style="min-width:100%;">
                            <thead>
                                <tr id="matrixHeader">
                                    <th style="min-width:100px;">Colour ↓ / Size →</th>
                                </tr>
                            </thead>
                            <tbody id="matrixBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        var existingDetails = @Html.Raw(Json.Serialize(Model.Details.Select(d => new { colour = d.Colour, size = d.Size, quantity = d.Quantity })));
    </script>
    <script src="~/js/production-edit.js"></script>
}
