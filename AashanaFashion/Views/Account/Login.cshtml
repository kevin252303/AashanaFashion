@model AashanaFashion.Models.LoginViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Sign In";
}

<div class="login-left">
    <div class="login-left-content">
        <div class="ll-logo">AF</div>
        <div class="ll-title">Aashana Fashion<br />Production System</div>
        <div class="ll-sub">Manage your production orders, track fabric stages, and monitor your team — all in one place.</div>
        <div class="ll-features">
            <div class="ll-feat"><div class="ll-feat-dot"></div> Real-time production order tracking</div>
            <div class="ll-feat"><div class="ll-feat-dot"></div> Role-based access control</div>
            <div class="ll-feat"><div class="ll-feat-dot"></div> Stage-wise verification workflow</div>
            <div class="ll-feat"><div class="ll-feat-dot"></div> User management dashboard</div>
        </div>
    </div>
</div>

<div class="login-right">
    <div class="login-box">
        <div class="lb-header">
            <div class="lb-title">Welcome back 👋</div>
            <div class="lb-sub">Sign in to your account to continue</div>
        </div>

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="lb-error">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }

            <div style="margin-bottom:1rem;">
                <label asp-for="Username" class="lb-label">Username</label>
                <input asp-for="Username" class="lb-input" placeholder="Enter your username" autofocus />
            </div>

            <div style="margin-bottom:1rem;">
                <label asp-for="Password" class="lb-label">Password</label>
                <div style="position:relative;">
                    <input asp-for="Password" class="lb-input" id="pwInput" placeholder="Enter your password" style="padding-right:2.5rem;" />
                    <button type="button" id="togglePw"
                            style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#94a3b8;font-size:.9rem;">👁</button>
                </div>
            </div>

            <div class="lb-remember">
                <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
                <label for="rememberMe">Keep me signed in</label>
            </div>

            <button type="submit" class="lb-btn">Sign In →</button>
        </form>

        <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid #f1f5f9;">
            <div style="font-size:.72rem;color:#cbd5e1;text-align:center;">
                © @DateTime.Now.Year Aashana Fashion · Production Management System
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('togglePw').addEventListener('click', function () {
            const i = document.getElementById('pwInput');
            i.type = i.type === 'password' ? 'text' : 'password';
        });
    </script>
}
