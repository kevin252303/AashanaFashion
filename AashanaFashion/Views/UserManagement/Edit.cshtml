@model AashanaFashion.Models.UserFormViewModel
@{
    ViewData["Title"] = "Edit User";
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-xl-5">
        <div class="data-card">
            <div class="data-card-header">
                <div>
                    <div class="data-card-title">Edit User — @Model.Username</div>
                    <div style="font-size:.75rem;color:#94a3b8;margin-top:.2rem;">ID #@Model.Id</div>
                </div>
                <a asp-action="Index" class="btn-af btn-af-ghost btn-af-sm">← Back</a>
            </div>
            <div style="padding:1.5rem;">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="af-alert af-alert-danger">
                            @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            { <div>@e.ErrorMessage</div> }
                        </div>
                    }

                    <div class="af-form-group">
                        <label asp-for="FullName" class="af-label">Full Name</label>
                        <input asp-for="FullName" class="af-input" />
                        <span asp-validation-for="FullName" class="af-error"></span>
                    </div>

                    <div class="af-form-group">
                        <label asp-for="Username" class="af-label">Username</label>
                        <input asp-for="Username" class="af-input" />
                        <span asp-validation-for="Username" class="af-error"></span>
                    </div>

                    <div class="af-form-group">
                        <label asp-for="Password" class="af-label">
                            New Password
                            <span style="font-weight:400;color:#94a3b8;">(leave blank to keep current)</span>
                        </label>
                        <div style="position:relative;">
                            <input asp-for="Password" class="af-input" id="pwInput" placeholder="Enter new password" style="padding-right:2.5rem;" />
                            <button type="button" id="togglePw"
                                    style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#94a3b8;">👁</button>
                        </div>
                        <span asp-validation-for="Password" class="af-error"></span>
                    </div>

                    <div class="af-form-group">
                        <label asp-for="Role" class="af-label">Role</label>
                        <select asp-for="Role" class="af-input af-select">
                            <option value="Admin">Admin — Full access</option>
                            <option value="Manager">Manager — View + Edit status</option>
                            <option value="Viewer">Viewer — Read only</option>
                        </select>
                    </div>

                    <div class="af-form-group">
                        <label style="display:flex;align-items:center;gap:.6rem;cursor:pointer;font-size:.83rem;color:#374151;">
                            <input asp-for="IsActive" type="checkbox" style="accent-color:#6366f1;width:16px;height:16px;" />
                            Active account
                        </label>
                    </div>

                    <div style="display:flex;gap:.75rem;margin-top:1.5rem;">
                        <button type="submit" class="btn-af btn-af-primary">Save Changes</button>
                        <a asp-action="Index" class="btn-af btn-af-ghost">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.getElementById('togglePw').addEventListener('click', function () {
            const i = document.getElementById('pwInput');
            i.type = i.type === 'password' ? 'text' : 'password';
        });
    </script>
}
