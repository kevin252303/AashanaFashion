@model AashanaFashion.Models.RolePermissionViewModel
@{
    ViewData["Title"] = "Assign Permissions";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Assign Permissions</h1>
        <p class="page-sub">Role: <strong>@Model.RoleName</strong></p>
    </div>
    <a asp-action="Index" class="btn-af btn-af-ghost btn-af-sm">← Back</a>
</div>

<form asp-action="Permissions" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UserRoleId" />
    <input type="hidden" asp-for="RoleName" />

    <div class="data-card">
        <div class="data-card-header">
            <span class="data-card-title">Module Permissions</span>
            <button type="button" id="selectAll" class="btn-af btn-af-ghost btn-af-sm">Select All</button>
        </div>
        <div style="padding:1rem;">
            <table class="af-table">
                <thead>
                    <tr>
                        <th style="min-width:200px;">Module</th>
                        <th class="text-center" style="min-width:100px;">
                            <div>View</div>
                            <input type="checkbox" class="col-toggle" data-col="view" style="accent-color:#6366f1;margin-top:.3rem;" title="Toggle all View" />
                        </th>
                        <th class="text-center" style="min-width:100px;">
                            <div>Create</div>
                            <input type="checkbox" class="col-toggle" data-col="create" style="accent-color:#6366f1;margin-top:.3rem;" title="Toggle all Create" />
                        </th>
                        <th class="text-center" style="min-width:100px;">
                            <div>Edit</div>
                            <input type="checkbox" class="col-toggle" data-col="edit" style="accent-color:#6366f1;margin-top:.3rem;" title="Toggle all Edit" />
                        </th>
                        <th class="text-center" style="min-width:100px;">
                            <div>Delete</div>
                            <input type="checkbox" class="col-toggle" data-col="delete" style="accent-color:#6366f1;margin-top:.3rem;" title="Toggle all Delete" />
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Modules.Count; i++)
                    {
                        <tr>
                            <td>
                                <input type="hidden" name="Modules[@i].Module" value="@Model.Modules[i].Module" />
                                <input type="hidden" name="Modules[@i].DisplayName" value="@Model.Modules[i].DisplayName" />
                                <strong>@Model.Modules[i].DisplayName</strong>
                                <div style="font-size:.75rem;color:#94a3b8;">@Model.Modules[i].Module</div>
                            </td>
                            <td class="text-center">
                                <input type="checkbox" name="Modules[@i].CanView" value="true"
                                       class="perm-check" data-col="view"
                                       @(Model.Modules[i].CanView ? "checked" : "")
                                       style="accent-color:#6366f1;width:18px;height:18px;" />
                                <input type="hidden" name="Modules[@i].CanView" value="false" />
                            </td>
                            <td class="text-center">
                                <input type="checkbox" name="Modules[@i].CanCreate" value="true"
                                       class="perm-check" data-col="create"
                                       @(Model.Modules[i].CanCreate ? "checked" : "")
                                       style="accent-color:#6366f1;width:18px;height:18px;" />
                                <input type="hidden" name="Modules[@i].CanCreate" value="false" />
                            </td>
                            <td class="text-center">
                                <input type="checkbox" name="Modules[@i].CanEdit" value="true"
                                       class="perm-check" data-col="edit"
                                       @(Model.Modules[i].CanEdit ? "checked" : "")
                                       style="accent-color:#6366f1;width:18px;height:18px;" />
                                <input type="hidden" name="Modules[@i].CanEdit" value="false" />
                            </td>
                            <td class="text-center">
                                <input type="checkbox" name="Modules[@i].CanDelete" value="true"
                                       class="perm-check" data-col="delete"
                                       @(Model.Modules[i].CanDelete ? "checked" : "")
                                       style="accent-color:#6366f1;width:18px;height:18px;" />
                                <input type="hidden" name="Modules[@i].CanDelete" value="false" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div style="padding:1rem 1.5rem;border-top:1px solid #f1f5f9;display:flex;gap:.75rem;">
            <button type="submit" class="btn-af btn-af-primary">💾 Save Permissions</button>
            <a asp-action="Index" class="btn-af btn-af-ghost">Cancel</a>
        </div>
    </div>
</form>

@section Scripts {
<script>
    // Column toggle (header checkbox toggles entire column)
    document.querySelectorAll('.col-toggle').forEach(function (toggle) {
        toggle.addEventListener('change', function () {
            var col = this.dataset.col;
            document.querySelectorAll('.perm-check[data-col="' + col + '"]').forEach(function (cb) {
                cb.checked = toggle.checked;
            });
        });
    });

    // Select All button
    document.getElementById('selectAll').addEventListener('click', function () {
        var allChecked = [...document.querySelectorAll('.perm-check')].every(cb => cb.checked);
        document.querySelectorAll('.perm-check, .col-toggle').forEach(cb => cb.checked = !allChecked);
        this.textContent = allChecked ? 'Select All' : 'Deselect All';
    });
</script>
}
